# Build outputs
**/build/
**/out/
**/bin/

# Gradle
.gradle/
**/gradle/wrapper/gradle-wrapper.jar

# IDE files
.idea/
*.iml
*.ipr
*.iws
.vscode/
desktop.ini

# JARs (built artifacts - don't commit these)
*.jar
# Exception: keep libs that are checked-in dependencies
!Tarnish/tarnish-client/libs/*.jar
!Tarnish/launcher/gradle/wrapper/gradle-wrapper.jar
!Tarnish/tarnish-client/gradle/wrapper/gradle-wrapper.jar
!Tarnish/tarnish-game/gradle/wrapper/gradle-wrapper.jar
!Tarnish/tarnish-client/allatori/allatori.jar
RuneCartel-Launcher.jar

# Update staging (generated by PUBLISH-UPDATE.bat)
update-staging/
Tarnish/tarnish-client/update-staging/

# Logs
*.log
data/error.log
data/info.log
data/warning.log

# Player profiles (runtime data)
Tarnish/tarnish-game/data/profile/

# Cache binary files (too large for git)
Tarnish/tarnish-game/data/cache/
Tarnish/launcher/src/main/resources/embedded/cache.zip

# Ban/mute files (runtime data)
Tarnish/tarnish-game/data/bans.txt
Tarnish/tarnish-game/data/ip-bans.txt
Tarnish/tarnish-game/data/ip-mutes.txt

# OS files
Thumbs.db
.DS_Store

# Sensitive - DO NOT commit these
# settings.toml contains Discord tokens, DB passwords, RSA keys
# Tarnish/tarnish-game/settings.toml
